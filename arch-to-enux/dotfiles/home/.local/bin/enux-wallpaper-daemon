#!/usr/bin/env bash
set -euo pipefail

if command -v swww-daemon >/dev/null 2>&1; then
    pgrep -x swww-daemon >/dev/null 2>&1 || nohup swww-daemon >/dev/null 2>&1 &
    exit 0
fi

if command -v awww-daemon >/dev/null 2>&1; then
    pgrep -x awww-daemon >/dev/null 2>&1 || nohup awww-daemon >/dev/null 2>&1 &
    exit 0
fi

exit 0
