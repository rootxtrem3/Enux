/* Generated by Matugen; symlink or copy ~/.cache/matugen/waybar.css */

* {
  border: none;
  border-radius: 0;
  font-family: "JetBrainsMono Nerd Font", "Noto Sans", "Cantarell", sans-serif;
  font-size: 10px;
  font-weight: 600;
  min-height: 0;
}

window#waybar {
  background: transparent;
  color: {{ colors.on_background.default.hex }};
}

.modules-left,
.modules-center,
.modules-right {
  margin-top: 1px;
}

#custom-launcher,
#workspaces,
#window,
#tray,
#network,
#pulseaudio,
#backlight,
#battery,
#cpu,
#memory,
#clock,
#custom-power {
  margin: 0 2px;
  padding: 3px 8px;
  border-radius: 999px;
  color: {{ colors.on_surface.default.hex }};
  background: rgba({{ colors.surface.default.red }}, {{ colors.surface.default.green }}, {{ colors.surface.default.blue }}, 0.78);
  border: 1px solid rgba({{ colors.outline.default.red }}, {{ colors.outline.default.green }}, {{ colors.outline.default.blue }}, 0.45);
}

#custom-launcher,
#custom-power {
  font-size: 12px;
  padding: 3px 7px;
}

#workspaces {
  padding: 2px 6px;
}

#workspaces button {
  color: {{ colors.on_surface_variant.default.hex }};
  min-width: 24px;
  min-height: 24px;
  margin: 0 3px;
  padding: 0;
  border-radius: 999px;
  background: transparent;
  box-shadow: inset 0 0 0 1px transparent;
  transition: background-color 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
}

#workspaces button label {
  padding: 0;
  min-width: 24px;
}

#workspaces button.active {
  color: {{ colors.on_primary.default.hex }};
  background: {{ colors.primary.default.hex }};
}

#workspaces button.urgent {
  color: {{ colors.on_error.default.hex }};
  background: {{ colors.error.default.hex }};
}

#workspaces button.empty {
  opacity: 0.82;
}

#window {
  padding-left: 8px;
  padding-right: 6px;
}

#tray {
  padding-right: 6px;
}

#battery.warning,
#battery.critical,
#battery.urgent {
  color: {{ colors.on_error.default.hex }};
  background: rgba({{ colors.error.default.red }}, {{ colors.error.default.green }}, {{ colors.error.default.blue }}, 0.9);
  border-color: {{ colors.error.default.hex }};
}

#pulseaudio.muted {
  color: {{ colors.on_surface_variant.default.hex }};
}

tooltip {
  background: {{ colors.surface_variant.default.hex }};
  color: {{ colors.on_surface.default.hex }};
  border-radius: 12px;
  border: 1px solid {{ colors.outline.default.hex }};
}
