{
  "layer": "top",
  "position": "top",
  "height": 28,
  "margin": "4 8 0 8",
  "spacing": 4,
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "tray",
    "network",
    "pulseaudio",
    "custom/cava",
    "backlight",
    "custom/hyprsunset",
    "battery",
    "cpu",
    "memory",
    "custom/power"
  ],
  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format": "{icon}",
    "sort-by-number": true,
    "persistent-workspaces": {
      "*": 6
    },
    "format-icons": {
      "1": "َ°² ",
      "2": "َ°²¢",
      "3": "َ°²¤",
      "4": "َ°²¦",
      "5": "َ°²¨",
      "6": "َ°²ھ",
      "7": "َ°²¬",
      "8": "َ°²®",
      "9": "َ°²°",
      "10": "َ°؟¬",
      "active": "ï†’",
      "default": "ï„Œ"
    }
  },
  "hyprland/window": {
    "separate-outputs": true,
    "max-length": 52,
    "rewrite": {
      "": "َ°£‡  Desktop"
    }
  },
  "tray": {
    "spacing": 8
  },
  "network": {
    "interval": 3,
    "format-wifi": "َ°¤¨  {signalStrength}%",
    "format-ethernet": "َ°ˆ€  {ipaddr}",
    "format-linked": "َ°ˆ€  {ifname}",
    "format-disconnected": "َ°–ھ",
    "on-click": "$HOME/.local/bin/enux-network-popup nmtui",
    "on-click-right": "$HOME/.local/bin/enux-network-popup list"
  },
  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon}  {volume}%",
    "format-muted": "َ°‌ں",
    "format-icons": {
      "default": [
        "َ°•؟",
        "َ°–€",
        "َ°•¾"
      ]
    },
    "on-click": "kitty -e pw-top"
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "َ°ƒ   {percent}%"
  },
  "custom/hyprsunset": {
    "return-type": "json",
    "format": "{}",
    "exec": "$HOME/.config/waybar/scripts/hyprsunset.sh",
    "interval": 5,
    "on-click": "$HOME/.config/waybar/scripts/hyprsunset.sh toggle",
    "on-click-right": "$HOME/.config/waybar/scripts/hyprsunset.sh warm",
    "on-click-middle": "$HOME/.config/waybar/scripts/hyprsunset.sh reset",
    "tooltip": true
  },
  "battery": {
    "interval": 10,
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "َ°‚„  {capacity}%",
    "format-plugged": "َ°ڑ¥  {capacity}%",
    "format-icons": [
      "َ°پ؛",
      "َ°پ»",
      "َ°پ¼",
      "َ°پ½",
      "َ°پ¾",
      "َ°پ؟",
      "َ°‚€",
      "َ°‚پ",
      "َ°‚‚",
      "َ°پ¹"
    ]
  },
  "cpu": {
    "interval": 3,
    "format": "ï’¼  {usage}%",
    "on-click": "kitty -e btop"
  },
  "memory": {
    "interval": 3,
    "format": "î؟…  {percentage}%",
    "on-click": "kitty -e btop"
  },
  "clock": {
    "interval": 1,
    "format": "َ°¥”  {:%a %d %b  %H:%M}",
    "tooltip-format": "{:%A, %B %d %Y  %H:%M:%S}"
  },
  "custom/launcher": {
    "format": " ",
    "tooltip": false,
    "on-click": "wofi --show drun"
  },
  "custom/power": {
    "format": "âڈ»",
    "tooltip": false,
