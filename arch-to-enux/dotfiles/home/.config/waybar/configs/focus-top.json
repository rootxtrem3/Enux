  },
  "custom/launcher": {
    "format": " ",
    "tooltip": false,
    "on-click": "wofi --show drun"
  },
  "custom/power": {
    "format": "َ°¤†",
    "tooltip": false,
    "on-click": "/home/rootx/.config/wofi/power.sh"
  }
}
