{
  "layer": "top",
  "position": "top",
  "height": 26,
  "margin": "4 8 0 8",
  "spacing": 4,
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "battery",
    "network",
    "pulseaudio",
    "custom/power"
  ],
  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format": "{icon}",
    "sort-by-number": true,
    "persistent-workspaces": {
      "*": 6
    },
    "format-icons": {
      "1": "َ°² ",
      "2": "َ°²¢",
      "3": "َ°²¤",
      "4": "َ°²¦",
      "5": "َ°²¨",
      "6": "َ°²ھ",
      "7": "َ°²¬",
      "8": "َ°²®",
      "9": "َ°²°",
      "10": "َ°؟¬",
      "active": "ï†’",
      "default": "ï„Œ"
    }
  },
  "hyprland/window": {
    "separate-outputs": true,
    "max-length": 46,
    "rewrite": {
      "": "َ°£‡  Focus"
    }
  },
  "network": {
    "interval": 3,
    "format-wifi": "َ°¤¥  {signalStrength}%",
    "format-ethernet": "َ°ˆپ  {ipaddr}",
    "format-linked": "َ°ˆپ  {ifname}",
    "format-disconnected": "َ°¤«",
    "on-click": "/home/rootx/.local/bin/enux-network-popup nmtui",
    "on-click-right": "/home/rootx/.local/bin/enux-network-popup list"
  },
  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon}  {volume}%",
    "format-muted": "َ°–پ",
