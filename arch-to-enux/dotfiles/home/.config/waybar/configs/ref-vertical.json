{
    "layer": "top", // Waybar at top layer
    "bar_id": "bar-0",
//    "mode": "dock",
    "ipc": true,
    "position": "right", // Waybar position (top|bottom|left|right)
     "height": 30, // Waybar height (to be removed for auto height)
    //"width": 100, // Waybar width
    "spacing": 10, // Gaps between modules (4px)
    "margin-bottom": 10,
//    "margin-left": 10,
    "margin-right": 10,
    "margin-top": 10,
    // Choose the order of the modules
    //"modules-left": [""sway/scratchpad", "custom/media", "sway/scratchpad", "custom/media"],
    //"modules-left": ["hyprland/window", "sway/window"],
    "modules-center": ["sway/workspaces", "hyprland/workspaces", "sway/mode","group/cpu", "group/memory", "keyboard-state", "group/battery", "battery#bat2", "group/pulseaudio", "group/backlight", "group/date", "group/time", "tray"],
     //"modules-right": ["cpu", "memory", "keyboard-state", "battery", "battery#bat2", "pulseaudio", "backlight", "group/time", "tray"],
    // "network", "mpd",

	"group/cpu": {
		"orientation": "vertical",
		"modules": [
			"cpu",
			"cpu#2"
		]
},
	"group/memory": {
		"orientation": "vertical",
		"modules": [
			"memory",
			"memory#2"
		]
},
	"group/battery": {
		"orientation": "vertical",
		"modules": [
			"battery",
			"battery#2"
		]
},
	"group/pulseaudio": {
		"orientation": "vertical",
		"modules": [
			"pulseaudio",
			"pulseaudio#2"
		]
},
	"group/backlight": {
		"orientation": "vertical",
		"modules": [
			"backlight",
			"backlight#2"
		]
},
	"group/date": {
		"orientation": "vertical",
		"modules": [
			"clock",
			"clock#2",
			"clock#3"
		]
},
	"group/time": {
		"orientation": "vertical",
		"modules": [
			"clock#4",
			"clock#5",
			"clock#6"
		]
},

    // Modules configuration
     "sway/workspaces": {
        "icon-size": 36,
         "disable-scroll": false,
         "all-outputs": true,
//         "format": "{name}: {icon}", 
         "format": "{icon}", 
         "format-icons": {
//             "1": "´äá",
//             "2": "´ëĘ",
//             "3": "´äí",
//             "4": "´ć╝",
//             "5": "´üÁ",
//             "urgent": "´ü¬",
             "urgent": "´ćĺ",
             "focused": "´ćĺ",
             "default": "´äĹ"
         }
},
     "hyprland/workspaces": {
	"on-click": "activate",
         "disable-scroll": false,
         "all-outputs": true,
         "format": "{icon}", 
         "format-icons": {
             "active": "´ćĺ",
             "urgent": "´ćĺ",
             "default": "´äĹ"
         }
},
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "´Çú",
            "unlocked": "´éť"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "´őĺ"],
        "tooltip": true,
    "tooltip-format": "{app}: {title}"
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) ÔŞĘ{songPosition}|{queueLength}ÔŞę {volume}% ´Çü",
        "format-disconnected": "Disconnected ´Çü",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ´Çü",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": "´âä "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">´ü┤</span> ",
            "on": "´ü┤ "
        },
        "repeat-icons": {
            "on": "´Ç× "
        },
        "single-icons": {
            "on": "´Ç×1 "
        },
        "state-icons": {
            "paused": "´üî",
            "playing": "´üő"
        },
    "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },
    "tray": {
        "icon-size": 36,
        "spacing": 10
    },
    "clock": {
        // "timezone": "America/New_York",
	"interval": 1,
	"format": "{:%y}",
    "tooltip-format": "{:%A, %B %d %Y  %H:%M:%S}"
    },
    "clock#2": {
        // "timezone": "America/New_York",
	"interval": 1,
	"format": "{:%b}",
    "tooltip-format": "{:%A, %B %d %Y  %H:%M:%S}"
    },
    "clock#3": {
        // "timezone": "America/New_York",
	"interval": 1,
	"format": "{:%d}",
    "tooltip-format": "{:%A, %B %d %Y  %H:%M:%S}"
    },
    "clock#4": {
        // "timezone": "America/New_York",
	"interval": 1,
	"format": "{:%H}",
    "tooltip-format": "{:%A, %B %d %Y  %H:%M:%S}"
    },
    "clock#5": {
        // "timezone": "America/New_York",
	"interval": 1,
	"format": "{:%M}",
    "tooltip-format": "{:%A, %B %d %Y  %H:%M:%S}"
    },
    "clock#6": {
        // "timezone": "America/New_York",
	"interval": 1,
	"format": "{:%OS}",
    "tooltip-format": "{:%A, %B %d %Y  %H:%M:%S}"
    },
    "cpu": {
        "interval": 1,
        "format": "{usage}%",
        "tooltip": true
    },
    "cpu#2": {
        "interval": 1,
        "format": "´őŤ",
        "tooltip": true
    },
    "memory": {
        "format": "{}%"
    },
    "memory#2": {
        "format": "´âë"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["´Łź", "´őë", "´Łę"]
    },

    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{capacity}%",
        "format-charging": "{capacity}%",
        "format-plugged": "{capacity}%",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },
    "battery#2": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon} ",
        "format-charging": "´Śž",
        "format-plugged": "´çŽ",
        "format-alt": "{time} {icon} ",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) ´çź",
        "format-ethernet": "{ipaddr}/{cidr} ´×ľ",
    "tooltip-format": "{ifname} via {gwaddr} ´×ľ",
        "format-linked": "{ifname} (No IP) ´×ľ",
        "format-disconnected": "Disconnected ÔÜá",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 5, // %, can be a float
        "format": "{volume}%",
        "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
        "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
        "format-muted": "´Üę {format_source}",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "on-click": "pavucontrol"
    },
    "pulseaudio#2": {
        // "scroll-step": 5, // %, can be a float
        "format": "{icon}",
        "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
        "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
        "format-muted": "´Üę {format_source}",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "on-click": "pavucontrol"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}%",
        "format-icons": ["ţÄŹ", "ţĆô", "ţĆĹ", "ţĆĆ", "ţĆÄ", "ţĆŹ", "ţĆŐ", "ţĆł", "ţÄŤ"]
    },
    "backlight#2": {
        // "device": "acpi_video1",
        "format": "{icon}",
        "format-icons": ["ţÄŹ", "ţĆô", "ţĆĹ", "ţĆĆ", "ţĆÄ", "ţĆŹ", "ţĆŐ", "ţĆł", "ţÄŤ"]
    },
    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "´ć╝",
            "default": "­čÄť"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    }
}
