{
    "layer": "top", // Waybar at top layer
    "bar_id": "bar-0",
//    "mode": "dock",
    "ipc": true,
    "position": "right", // Waybar position (top|bottom|left|right)
     //"height": 30, // Waybar height (to be removed for auto height)
    //"width": 100, // Waybar width
    "spacing": 50, // Gaps between modules (4px)
    "margin-bottom": 10,
    "margin-left": -10,
    "margin-right": 10,
    "margin-top": 10,
    // Choose the order of the modules
    //"modules-left": [""sway/scratchpad", "custom/media", "sway/scratchpad", "custom/media"],
    //"modules-left": ["hyprland/window", "sway/window"],
    "modules-center": ["sway/workspaces", "hyprland/workspaces", "sway/mode","group/cpu", "group/memory", "keyboard-state", "group/battery", "battery#bat2", "group/pulseaudio", "group/backlight", "group/date", "group/time", "tray"],
     //"modules-right": ["cpu", "memory", "keyboard-state", "battery", "battery#bat2", "pulseaudio", "backlight", "group/time", "tray"],
    // "network", "mpd",

	"group/cpu": {
		"orientation": "vertical",
		"modules": [
			"cpu",
			"cpu#2"
		]
},
	"group/memory": {
		"orientation": "vertical",
		"modules": [
			"memory",
			"memory#2"
		]
},
	"group/battery": {
		"orientation": "vertical",
		"modules": [
			"battery",
			"battery#2"
		]
},
	"group/pulseaudio": {
		"orientation": "vertical",
		"modules": [
			"pulseaudio",
			"pulseaudio#2"
		]
},
	"group/backlight": {
		"orientation": "vertical",
		"modules": [
			"backlight",
			"backlight#2"
		]
},
	"group/date": {
		"orientation": "vertical",
		"modules": [
			"clock#3",
			"clock#2",
			"clock"
		]
},
	"group/time": {
		"orientation": "vertical",
		"modules": [
			"clock#4",
			"clock#5",
			"clock#6"
		]
},

    // Modules configuration
     "sway/workspaces": {
         "disable-scroll": false,
         "all-outputs": true,
//         "format": "{name}: {icon}", 
         "format": "{icon}", 
         "format-icons": {
//             "1": "п„ ",
//             "2": "п‰Ё",
//             "3": "п„Ў",
//             "4": "п†ј",
//             "5": "пЃµ",
//             "urgent": "пЃЄ",
             "urgent": "п†’",
             "focused": "п†’",
             "default": "п„‘"
         }
},
     "hyprland/workspaces": {
	"on-click": "activate",
         "disable-scroll": false,
         "all-outputs": true,
         "format": "{icon}", 
         "format-icons": {
             "active": "п†’",
             "urgent": "п†’",
             "default": "п„‘"
         }
},
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "пЂЈ",
            "unlocked": "п‚њ"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "п‹’"],
        "tooltip": true,
    "tooltip-format": "{app}: {title}"
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) вёЁ{songPosition}|{queueLength}вё© {volume}% пЂЃ",
        "format-disconnected": "Disconnected пЂЃ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped пЂЃ",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": "пѓ„ "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">пЃґ</span> ",
            "on": "пЃґ "
        },
        "repeat-icons": {
            "on": "пЂћ "
        },
        "single-icons": {
            "on": "пЂћ1 "
        },
        "state-icons": {
            "paused": "пЃЊ",
            "playing": "пЃ‹"
        },
    "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пЃ®",
            "deactivated": "пЃ°"
        }
    },
    "tray": {
        "icon-size": 24,
        "spacing": 10
    },
    "clock": {
        // "timezone": "America/New_York",
	"interval": 1,
	"format": "{:%Y}",
    "tooltip-format": "{:%A, %B %d %Y  %H:%M:%S}"
    },
    "clock#2": {
        // "timezone": "America/New_York",
	"interval": 1,
	"format": "{:%b}",
    "tooltip-format": "{:%A, %B %d %Y  %H:%M:%S}"
    },
    "clock#3": {
        // "timezone": "America/New_York",
	"interval": 1,
	"format": "{:%d}",
    "tooltip-format": "{:%A, %B %d %Y  %H:%M:%S}"
    },
    "clock#4": {
        // "timezone": "America/New_York",
	"interval": 1,
	"format": "{:%H}",
    "tooltip-format": "{:%A, %B %d %Y  %H:%M:%S}"
    },
    "clock#5": {
        // "timezone": "America/New_York",
	"interval": 1,
	"format": "{:%M}",
    "tooltip-format": "{:%A, %B %d %Y  %H:%M:%S}"
    },
    "clock#6": {
        // "timezone": "America/New_York",
	"interval": 1,
	"format": "{:%OS}",
    "tooltip-format": "{:%A, %B %d %Y  %H:%M:%S}"
    },
    "cpu": {
        "interval": 1,
        "format": "{usage}%",
        "tooltip": true
    },
    "cpu#2": {
        "interval": 1,
        "format": "п‹›",
        "tooltip": true
    },
    "memory": {
        "format": "{}%"
    },
    "memory#2": {
        "format": "пѓ‰"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}В°C {icon}",
        "format": "{temperatureC}В°C {icon}",
        "format-icons": ["пќ«", "п‹‰", "пќ©"]
    },

    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{capacity}%",
        "format-charging": "{capacity}%",
        "format-plugged": "{capacity}%",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
    },
    "battery#2": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon} ",
        "format-charging": "п—§",
        "format-plugged": "п‡¦",
        "format-alt": "{time} {icon} ",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) п‡«",
        "format-ethernet": "{ipaddr}/{cidr} пћ–",
    "tooltip-format": "{ifname} via {gwaddr} пћ–",
        "format-linked": "{ifname} (No IP) пћ–",
        "format-disconnected": "Disconnected вљ ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 5, // %, can be a float
        "format": "{volume}%",
        "format-bluetooth": "{volume}%",
        "format-bluetooth-muted": "mute",
        "format-muted": "{volume}%",
        "format-source": "{volume}% п„°",
        "format-source-muted": "п„±",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "п–ђ",
            "headset": "пЂҐ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "on-click": "pavucontrol"
    },
    "pulseaudio#2": {
        // "scroll-step": 5, // %, can be a float
        "format": "{icon}",
        "format-bluetooth": "пЉ”",
        "format-bluetooth-muted": "пЉ”",
        "format-muted": "{format_source}",
        "format-source": "{volume}% п„°",
        "format-source-muted": "п„±",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "п–ђ",
            "headset": "пЂҐ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "on-click": "pavucontrol"
    },
    "pulseaudio#3": {
        // "scroll-step": 5, // %, can be a float
        "format": "{icon}",
        "format-bluetooth": "{icon}  пЉ” {format_source}",
        "format-bluetooth-muted": "пљ© {icon}  пЉ” {format_source}",
        "format-muted": "пљ© {format_source}",
        "format-source": "{volume}% п„°",
        "format-source-muted": "п„±",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "п–ђ",
            "headset": "пЂҐ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "on-click": "pavucontrol"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}%",
        "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"]
    },
    "backlight#2": {
        // "device": "acpi_video1",
        "format": "{icon}",
        "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"]
    },
    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "п†ј",
            "default": "рџЋњ"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    }
}
