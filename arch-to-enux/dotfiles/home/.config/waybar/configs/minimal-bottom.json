{
  "layer": "top",
  "position": "bottom",
  "height": 26,
  "margin": "0 8 6 8",
  "spacing": 4,
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "network",
    "pulseaudio",
    "battery",
    "custom/power"
  ],
  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format": "{icon}",
    "sort-by-number": true,
    "persistent-workspaces": {
      "*": 6
    },
    "format-icons": {
      "1": "≤░▓ι",
      "2": "≤░▓λ",
      "3": "≤░▓ν",
      "4": "≤░▓ο",
      "5": "≤░▓ρ",
      "6": "≤░▓ς",
      "7": "≤░▓υ",
      "8": "≤░▓χ",
      "9": "≤░▓░",
      "10": "≤░┐υ",
      "active": "ΎΗΤ",
      "default": "ΎΕΝ"
    }
  },
  "network": {
    "interval": 3,
    "format-wifi": "≤░νψ  {signalStrength}%",
    "format-ethernet": "≤░ΙΒ  {ipaddr}",
    "format-linked": "≤░ΙΒ  {ifname}",
    "format-disconnected": "≤░νφ",
    "on-click": "/home/rootx/.local/bin/enux-network-popup nmtui",
    "on-click-right": "/home/rootx/.local/bin/enux-network-popup list"
  },
  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon}  {volume}%",
    "format-muted": "≤░ΨΒ",
    "format-icons": {
      "default": [
        "ΎΑο",
        "ΎΑπ",
        "ΎΑρ"
      ]
    },
    "on-click": "kitty -e pw-top"
  },
  "battery": {
    "interval": 10,
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "format": "≤░Β╣  {capacity}%",
    "format-charging": "≤░ΓΕ  {capacity}%",
    "format-plugged": "≤░γξ  {capacity}%",
    "format-icons": [
      "≤░Β║",
      "≤░Β╗",
      "≤░Β╝",
      "≤░Β╜",
      "≤░Β╛",
      "≤░Β┐",
      "≤░ΓΑ",
      "≤░ΓΒ",
      "≤░ΓΓ",
      "≤░Β╣"
    ]
  },
  "clock": {
    "interval": 1,
    "format": "≤░ΖΡ  {:%H:%M}",
    "tooltip-format": "{:%A, %B %d %Y  %H:%M:%S}"
  },
  "custom/launcher": {
    "format": " ",
    "tooltip": false,
    "on-click": "wofi --show drun"
  },
  "custom/power": {
    "format": "≤░Ρξ",
    "tooltip": false,
    "on-click": "/home/rootx/.config/wofi/power.sh"
  }
}
